# Server
PORT=3000

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co

# Use the Service Role key for full backend access (bypasses RLS).
# The Anon key works too but RLS policies will restrict queries.
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# JWT — generate a strong random secret, e.g.: openssl rand -hex 64
JWT_SECRET=your-very-long-random-secret-string
