# .env.production — Pulse Backend Production Environment
# Copy this file to .env and replace every placeholder with real values.
# NEVER commit a filled-in .env to version control.

# ------------------------------------------------------------
# Server
# ------------------------------------------------------------
PORT=3000

# ------------------------------------------------------------
# Supabase
# Get these from: https://supabase.com/dashboard → Project Settings → API
# ------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ------------------------------------------------------------
# Anthropic
# Get your key from: https://console.anthropic.com/settings/api-keys
# ------------------------------------------------------------
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# ------------------------------------------------------------
# JWT
# Generate a strong secret: openssl rand -hex 64
# (or in PowerShell: [Convert]::ToBase64String((1..64 | % { Get-Random -Max 256 })))
# ------------------------------------------------------------
JWT_SECRET=YOUR_VERY_LONG_RANDOM_SECRET_STRING_MIN_32_CHARS
